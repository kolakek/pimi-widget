<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Config.Coordinator" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
    </style>

    <style name="Config.AppBar" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="liftOnScrollColor">?attr/colorSurfaceContainerHighest</item>
    </style>

    <style name="Config.MaterialDialogAlert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="dialogCornerRadius">28dp</item>
        <item name="android:colorBackground">?attr/colorSurfaceBright</item>
    </style>

    <style name="Widget.Base" parent="android:Widget">
        <item name="android:background">#00000000</item>
        <item name="android:clipToOutline">true</item>
    </style>

    <style name="Widget.Container" parent="Widget.Base">
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.InnerContainer" parent="Widget.Base">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.InnerView" parent="Widget.Base">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.DateAlarm" parent="Widget.InnerView">
        <item name="android:layout_height">@dimen/widget_date_height</item>
        <item name="android:textSize" tools:ignore="SpUsage">18dp</item>
    </style>

    <style name="Widget.Date" parent="Widget.DateAlarm">
        <item name="android:format12Hour">@string/widget_date_format</item>
        <item name="android:format24Hour">@string/widget_date_format</item>
        <item name="android:layout_marginRight">12dp</item>
    </style>

    <style name="Widget.DateDark" parent="Widget.Date">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.DateLight" parent="Widget.Date">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.DateLightShadow" parent="Widget.Date">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Alarm" parent="Widget.DateAlarm">
        <item name="android:drawablePadding">4dp</item>
    </style>

    <style name="Widget.AlarmDark" parent="Widget.Alarm">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.AlarmLight" parent="Widget.Alarm">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.AlarmLightShadow" parent="Widget.Alarm">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Weather" parent="Widget.InnerView">
        <item name="android:layout_height">@dimen/widget_weather_height</item>
        <item name="android:textSize" tools:ignore="SpUsage">16dp</item>
        <item name="android:drawablePadding">2dp</item>
    </style>

    <style name="Widget.WeatherDark" parent="Widget.Weather">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.WeatherLight" parent="Widget.Weather">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.WeatherLightShadow" parent="Widget.Weather">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Aux" parent="Widget.InnerView">
        <item name="android:layout_height">@dimen/widget_aux_height</item>
        <item name="android:textSize" tools:ignore="SpUsage">12dp</item>
    </style>

    <style name="Widget.AuxDark" parent="Widget.Aux">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.AuxLight" parent="Widget.Aux">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.AuxLightShadow" parent="Widget.Aux">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Spacer" parent="Widget.InnerView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/widget_spacer_height</item>
    </style>

</resources>
