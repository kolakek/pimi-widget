<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Widget.PimiWidget.Configure.Coordinator" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
    </style>

    <style name="Widget.PimiWidget.Configure.AppBar" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="liftOnScrollColor">?attr/colorSurfaceContainerHighest</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.Container" parent="android:Widget">
        <item name="android:id">@android:id/background</item>
        <item name="android:paddingHorizontal">@dimen/widget_padding_horz</item>
        <item name="android:background">#00000000</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">top</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.InnerView" parent="android:Widget">
        <item name="android:background">#00000000</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.Date" parent="Widget.PimiWidget.AppWidget.InnerView">
        <item name="android:gravity">bottom</item>
        <item name="android:layout_height">@dimen/widget_date_height</item>
        <item name="android:textSize" tools:ignore="SpUsage">20dp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:format12Hour">@string/widget_date_format</item>
        <item name="android:format24Hour">@string/widget_date_format</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.DateDark" parent="Widget.PimiWidget.AppWidget.Date">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.DateLight" parent="Widget.PimiWidget.AppWidget.Date">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.DateLightShadow" parent="Widget.PimiWidget.AppWidget.Date">
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.Weather" parent="Widget.PimiWidget.AppWidget.InnerView">
        <item name="android:layout_height">@dimen/widget_weather_height</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textSize" tools:ignore="SpUsage">16dp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:drawablePadding">2dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:visibility">invisible</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.WeatherDark" parent="Widget.PimiWidget.AppWidget.Weather">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.WeatherLight" parent="Widget.PimiWidget.AppWidget.Weather">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.WeatherLightShadow" parent="Widget.PimiWidget.AppWidget.Weather">
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.Aux" parent="Widget.PimiWidget.AppWidget.InnerView">
        <item name="android:layout_height">@dimen/widget_aux_height</item>
        <item name="android:textSize" tools:ignore="SpUsage">12dp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:visibility">invisible</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.AuxDark" parent="Widget.PimiWidget.AppWidget.Aux">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.AuxLight" parent="Widget.PimiWidget.AppWidget.Aux">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.AuxLightShadow" parent="Widget.PimiWidget.AppWidget.Aux">
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.PimiWidget.AppWidget.MaterialDialogAlert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="dialogCornerRadius">28dp</item>
        <item name="android:colorBackground">?attr/colorSurfaceBright</item>
    </style>

</resources>
