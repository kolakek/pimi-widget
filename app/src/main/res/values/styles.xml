<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Config.Coordinator" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
    </style>

    <style name="Config.AppBar" parent="">
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="liftOnScrollColor">?attr/colorSurfaceContainerHighest</item>
    </style>

    <style name="Config.MaterialDialogAlert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="dialogCornerRadius">28dp</item>
        <item name="android:colorBackground">?attr/colorSurfaceBright</item>
    </style>

    <style name="Widget.Base" parent="android:Widget">
        <item name="android:background">#00000000</item>
        <item name="android:clipToOutline">true</item>
    </style>

    <style name="Widget.VerticalContainer" parent="Widget.Base">
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.InnerHorizontalContainer" parent="Widget.Base">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.InnerVerticalContainer" parent="Widget.Base">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.InnerView" parent="Widget.Base">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.DateEvent" parent="Widget.InnerView">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginVertical">4dp</item>
    </style>

    <style name="Widget.Date" parent="Widget.DateEvent">
        <item name="android:format12Hour">@string/widget_date_format</item>
        <item name="android:format24Hour">@string/widget_date_format</item>
        <item name="android:layout_marginRight">8dp</item>
    </style>

    <style name="Widget.DateShadow" parent="Widget.Date">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <style name="Widget.Event" parent="Widget.DateEvent">
        <item name="android:drawablePadding">0dp</item>
    </style>

    <style name="Widget.EventShadow" parent="Widget.Event">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <style name="Widget.WeatherIcon" parent="Widget.Base">
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <style name="Widget.Weather" parent="Widget.InnerView">
        <item name="android:drawablePadding">2dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginVertical">6dp</item>
    </style>

    <style name="Widget.WeatherShadow" parent="Widget.Weather">
        <item name="android:shadowColor">#222222</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">1</item>
    </style>

    <style name="Widget.HorizontalContainerSolid" parent="Widget.Base">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginHorizontal">8dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:background">@drawable/widget_background</item>
        <item name="android:baselineAligned">false</item>
    </style>

    <style name="Widget.InnerVerticalContainerSolid" parent="Widget.InnerVerticalContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="Widget.WeatherContainerSolid" parent="Widget.Base">
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_width">60dp</item>
        <item name="android:background">@drawable/widget_icon_background</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="Widget.WeatherIconSolid" parent="Widget.Base">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
    </style>

    <style name="Widget.WeatherTempSolid" parent="Widget.Base">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/dynamic_temp_color</item>
        <item name="android:textSize" tools:ignore="SpUsage">14dp</item>
    </style>

    <style name="Widget.DateEventSolid" parent="Widget.InnerView">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/dynamic_text_color</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginVertical">2dp</item>
    </style>

    <style name="Widget.DateSolid" parent="Widget.DateEventSolid">
        <item name="android:format12Hour">@string/widget_date_format</item>
        <item name="android:format24Hour">@string/widget_date_format</item>
        <item name="android:layout_marginRight">8dp</item>
    </style>

    <style name="Widget.WeatherSolid" parent="Widget.InnerView">
        <item name="android:textColor">@color/dynamic_text_color</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginVertical">4dp</item>
    </style>

</resources>
