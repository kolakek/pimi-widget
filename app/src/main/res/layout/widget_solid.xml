<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.ContainerSolid"
    android:id="@+id/widget_root">

    <LinearLayout
        style="@style/Widget.InnerHorizontalContainer"
        android:layout_width="match_parent"
        android:baselineAligned="false">

        <LinearLayout
            style="@style/Widget.InnerVerticalContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <LinearLayout
                style="@style/Widget.InnerHorizontalContainer">

                <TextClock
                    style="@style/Widget.DateSolid"
                    android:id="@+id/widget_text_clock" />

                <TextView
                    style="@style/Widget.DateEventSolid"
                    android:id="@+id/widget_alarm" />

                <TextView
                    style="@style/Widget.DateEventSolid"
                    android:id="@+id/widget_birthday" />

            </LinearLayout>

            <TextView
                style="@style/Widget.WeatherSolid"
                android:id="@+id/widget_weather_info" />

            <TextView
                style="@style/Widget.AuxSolid"
                android:id="@+id/widget_aux" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/widget_icon_background"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/widget_weather_icon"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/widget_weather_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/dynamic_temp_color"
                android:textSize="14dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
