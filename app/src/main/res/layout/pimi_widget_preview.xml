<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.PimiWidget.AppWidget.Container"
    android:theme="@style/Theme.PimiWidget.AppWidgetContainer">

    <TextView
        style="@style/Widget.PimiWidget.AppWidget.Date"
        android:text="@string/widget_date_prev" />

    <TextView
        style="@style/Widget.PimiWidget.AppWidget.Weather"
        android:layout_width="wrap_content"
        android:text="@string/widget_temp_prev"
        android:maxLines="1"
        android:ellipsize="end"
        android:drawableStart="@drawable/uc_0d"
        tools:ignore="UseCompatTextViewDrawableXml" />

</LinearLayout>
