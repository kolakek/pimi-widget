<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:theme="@style/Theme.PimiWidget"
    style="@style/Widget.ContainerSolid">

    <TextView
        style="@style/Widget.DateSolid"
        android:textColor="?attr/widgetPreviewTextColor"
        android:text="@string/widget_date_prev" />

    <TextView
        style="@style/Widget.WeatherSolid"
        android:textColor="?attr/widgetPreviewTextColor"
        android:text="@string/widget_temp_prev"
        android:drawableStart="?attr/widgetPreviewWeatherIcon"
        tools:ignore="UseCompatTextViewDrawableXml" />

</LinearLayout>
