<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.PimiWidget.AppWidget.Container"
    android:theme="@style/Theme.PimiWidget.AppWidgetContainer">

    <TextClock
        style="@style/Widget.PimiWidget.AppWidget.DateLightShadow"
        android:id="@+id/widget_text_clock"
        android:format12Hour="@string/widget_date_format"
        android:format24Hour="@string/widget_date_format" />

    <TextView
        style="@style/Widget.PimiWidget.AppWidget.WeatherLightShadow"
        android:id="@+id/widget_temp"
        android:layout_width="wrap_content"
        android:visibility="invisible"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
