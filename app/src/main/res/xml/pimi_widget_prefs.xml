<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:key="category_settings"
        android:selectable="false"
        android:title="@string/config_settings_sec"
        app:iconSpaceReserved="false"
        app:allowDividerAbove="false"
        app:allowDividerBelow="false" >

        <SwitchPreferenceCompat
            android:key="weather_switch"
            android:summary="@string/config_weather_descr"
            android:title="@string/config_weather_switch"
            android:widgetLayout="@layout/preference_switch"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="weather_view"
            android:summary="@string/config_weather_view_descr"
            android:title="@string/config_weather_view"
            app:iconSpaceReserved="false" />

        <CheckBoxPreference
            android:key="daily_forecast"
            android:title="@string/config_daily_forecast"
            android:summary="@string/config_daily_forecast_descr"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:defaultValue="temp_unit_celsius"
            android:entries="@array/temp_units"
            android:entryValues="@array/temp_units_vals"
            android:key="temp_list"
            android:title="@string/config_temp"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="icon_style_outlined"
            android:entries="@array/icon_styles"
            android:entryValues="@array/icon_styles_vals"
            android:key="icon_style_list"
            android:title="@string/config_icon_style"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="color_auto"
            android:entries="@array/colors"
            android:entryValues="@array/colors_vals"
            android:key="text_color_list"
            android:title="@string/config_text_color"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="category_about"
        android:selectable="false"
        android:title="@string/config_about_sec"
        app:iconSpaceReserved="false"
        app:allowDividerAbove="false"
        app:allowDividerBelow="false" >

        <Preference
            android:key="weather_data"
            android:summary="@string/config_provider_descr"
            android:title="@string/config_weather_data"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="source_code"
            android:summary="@string/config_source_code_descr"
            android:title="@string/config_source_code"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</androidx.preference.PreferenceScreen>