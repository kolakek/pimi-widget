<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:key="category_settings"
        android:selectable="false"
        android:title="@string/config_section_settings"
        app:iconSpaceReserved="false"
        app:allowDividerAbove="false"
        app:allowDividerBelow="false">

        <SwitchPreferenceCompat
            android:key="alarm_switch"
            android:summary="@string/config_show_alarms_descr"
            android:title="@string/config_show_alarms"
            android:widgetLayout="@layout/preference_switch"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="weather_switch"
            android:summary="@string/config_weather_switch_summary"
            android:title="@string/config_weather_switch"
            android:widgetLayout="@layout/preference_switch"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <CheckBoxPreference
            android:key="location_fallback"
            android:title="@string/config_location_fallback"
            android:summary="@string/config_location_fallback_summary"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <CheckBoxPreference
            android:key="daily_forecast"
            android:title="@string/config_daily_forecast"
            android:summary="@string/config_daily_forecast_summary"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <CheckBoxPreference
            android:key="weather_warnings"
            android:title="@string/config_weather_warnings"
            android:summary="@string/config_weather_warnings_summary"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:defaultValue="aux_view_nothing"
            android:entries="@array/aux_views"
            android:entryValues="@array/aux_views_vals"
            android:key="aux_view_list"
            android:title="@string/config_aux_view_title"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="icon_style_outlined"
            android:entries="@array/icon_styles"
            android:entryValues="@array/icon_styles_vals"
            android:key="icon_style_list"
            android:title="@string/config_icon_style"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="weather_app_default"
            android:entries="@array/weather_apps"
            android:entryValues="@array/weather_apps_vals"
            android:key="weather_app_list"
            android:title="@string/config_weather_app"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="category_settings_plus"
        android:selectable="false"
        android:title="@string/config_section_settings_plus"
        app:isPreferenceVisible="false"
        app:iconSpaceReserved="false"
        app:allowDividerAbove="false"
        app:allowDividerBelow="false">

        <ListPreference
            android:defaultValue="temp_unit_auto"
            android:entries="@array/temp_units"
            android:entryValues="@array/temp_units_vals"
            android:key="temp_list"
            android:title="@string/config_temp"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="color_auto"
            android:entries="@array/colors"
            android:entryValues="@array/colors_vals"
            android:key="text_color_list"
            android:title="@string/config_text_color"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="color_auto"
            android:entries="@array/colors"
            android:entryValues="@array/colors_vals"
            android:key="icon_color_list"
            android:title="@string/config_icon_color"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="category_about"
        android:selectable="false"
        android:title="@string/config_section_about"
        app:iconSpaceReserved="false"
        app:allowDividerAbove="false"
        app:allowDividerBelow="false">

        <Preference
            android:key="source_code"
            android:summary="@string/config_source_code_summary"
            android:title="@string/config_source_code"
            app:iconSpaceReserved="false" />

        <com.kolakek.pimiwidget.settings.LongPressPreference
            android:key="build_number"
            android:title="@string/config_version_title"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</androidx.preference.PreferenceScreen>
